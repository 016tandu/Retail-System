    U[Retailer/Staff hợp lệ]:::actor
    SYS[[Hệ thống Hóa đơn]]

    UC1([Nhập thông tin hóa đơn]):::usecase
    UC2([Kiểm tra quyền và trạng thái nhân sự]):::ext
    UC3([Kiểm tra tồn kho]):::ext
    UC4([Lưu hóa đơn + chi tiết]):::usecase
    UC5([Trừ tồn kho theo transaction]):::usecase
    UC6([Xuất mã hóa đơn thành công]):::usecase
